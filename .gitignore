# Test::Nginx runtime tree (regenerated per run)
t/servroot/
# fuzzer-discovered corpus entries are regenerated locally; the curated seed
# inputs (descriptively named, e.g. fuzz/corpus/one_record.bin) stay tracked,
# while these wildcards keep newly discovered hash-named inputs out of git.
fuzz/corpus/*
fuzz/corpus_statuses/*
